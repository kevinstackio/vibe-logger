#!/bin/bash
LOG_DIR="$PWD/.vibe-logs"

# Per-project disable
[ -f "$LOG_DIR/.disabled" ] && exit 0

TS=$(date "+%Y-%m-%d_%H-%M-%S")
PROJECT_NAME=$(basename "$PWD")

mkdir -p "$LOG_DIR"

# Generate README on first run
if [ ! -f "$LOG_DIR/README.md" ]; then
cat > "$LOG_DIR/README.md" <<'README'
# .vibe-logs

Auto-generated by [VibeLogger](https://github.com/kevinstackio/vibe-logger).
Records every Claude Code session automatically.

## Commands

- `log session` — manually log the current session
- `disable vibe logger` — stop auto-logging for this project
- `enable vibe logger` — resume auto-logging for this project
README
fi

BRANCH=$(git branch --show-current 2>/dev/null || echo "N/A")
COMMITS=$(git log --oneline -10 2>/dev/null | sed "s/^/- /" || echo "- No commits")
DIFF=$(git diff --stat HEAD 2>/dev/null || echo "No changes tracked")

cat > "$LOG_DIR/$TS.md" <<ENTRY
## $TS

**Project:** $PROJECT_NAME
**Branch:** \`$BRANCH\`
**Tool:** Claude Code
**Summary:** *(auto-logged on session stop)*

### Commits
$COMMITS

### Files touched
$DIFF
ENTRY
